# ---------------------------------------------------------------------------
# Pikorua HRM — environment variables (Phase 0 shared).
# Copy to `.env` at the repo root and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# Used by Prisma (prisma/schema.prisma reads env("DATABASE_URL")).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pikorua_hrm?schema=public"

# --- Auth ---
# Secret used to sign session JWTs (lib/auth). Generate a long random string:
#   openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-secret"
# Session lifetime in seconds (default 7 days).
AUTH_SESSION_MAX_AGE="604800"

# --- File storage (S3 / Cloudflare R2) — employee docs & reimbursement receipts ---
# Not required until Track B builds document/attachment upload.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="pikorua-hrm"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Scheduled jobs (cron-triggered API routes) ---
# Shared secret the cron caller sends (e.g. as a header) to authorize
# /api/v1/cron/* routes (birthday check, meeting reminders, recognition snapshots).
CRON_SECRET="change-me-cron-secret"

# --- LLM (Groq) — AI task generation ---
# Used by lib/ai/groq.ts for POST /work-units/:id/generate-tasks (breaks a
# WorkUnit brief into a SubUnit + WorkItem draft). Get a key at console.groq.com.
GROQ_API_KEY=""
# Optional — Groq-hosted model id. Defaults to llama-3.3-70b-versatile.
GROQ_MODEL="llama-3.3-70b-versatile"

# --- App ---
NEXT_PUBLIC_APP_NAME="Pikorua HRM"
# Public base URL (no trailing slash needed), used to build links in emails
# (e.g. the forgot-password reset link). https:// is assumed if no scheme is
# given.
APP_BASE_URL="http://localhost:3000"

# --- Email (Brevo) — password reset (added 2026-07-16) ---
# Used by lib/email/brevo.ts for POST /auth/forgot-password. Optional: if
# BREVO_API_KEY is missing, the route still responds normally but silently
# skips sending (logged at debug) rather than failing.
BREVO_API_KEY=""
# Must be a verified sender in your Brevo account.
BREVO_SENDER_EMAIL="pikoruaweb@gmail.com"
BREVO_SENDER_NAME="PIKORUA"

# --- Firebase Cloud Messaging (web push, added 2026-07-15) ---
# Optional: if any value below is missing, push is silently disabled (in-app
# notifications still work). Get the NEXT_PUBLIC_* values from Firebase
# Console → Project Settings → General → your Web App's config snippet.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# Project Settings → Cloud Messaging → Web configuration → Generate key pair.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""
# Server-side send credentials, from a service account key (Project Settings
# → Service Accounts → Generate new private key). Treat as secrets.
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""
